---
const { title, img, desc, url, badge, tags, target = "_blank" } = Astro.props;
import { Image } from "astro:assets";
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";
---

<div
  class="rounded-lg bg-base-100 border border-slate-800 transition-all duration-300 hover:scale-[102%] hover:border-blue-500/40 hover:shadow-[0_0_20px_rgba(59,130,246,0.1)] group"
>
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row">
      {
        img && (
          <Image
            src={img}
            width={750}
            height={422}
            format="webp"
            alt={title}
            class="max-w-full md:max-w-[13rem] rounded-lg"
          />
        )
      }
<div class="grow w-full">
  <h1 class="text-xl font-bold group-hover:text-blue-400 transition-colors">
    {title}
    {badge && (
      <div class="badge border-primary/30 bg-primary/10 text-primary mx-2 px-3 py-3 font-mono text-[10px] uppercase tracking-wider backdrop-blur-md">
        {badge}
      </div>
    )}
  </h1>
  <p class="py-1 text-1xl opacity-80">{desc}</p>
  <div class="card-actions justify-end mt-2">
    {
      tags &&
        tags.map((tag) => (
          <a href={`${tag_url}/${tag}`} 
             class="badge border-white/10 bg-white/5 text-white/70 text-[10px] font-mono hover:border-primary hover:text-primary transition-colors">
            #{tag}
          </a>
        ))
    }
  </div>
</div>
    </div>
  </a>
</div>
