---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold text-primary">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    Cloud Security & Infrastructure Leader with over 12 years of specialized experience in technical support and interface management. Expert in architecting secure, scalable healthcare data environments (HL7/FHIR) and managing enterprise AWS infrastructures. Proven track record in leading cross-functional teams, driving automation, and ensuring rigorous compliance with NIST and HIPAA security frameworks.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold text-primary">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="B.S. in Business Administration: Marketing & Management"
      subtitle="Montclair State University | New Jersey"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold text-primary">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Technical Services Manager"
      subtitle="September 2025 - Present at HealtHIE Nevada | Nevada (Remote)"
    >
      <ul class="list-disc ml-5 space-y-2">
        <li>Direct day-to-day technical operations, ensuring high availability, scalability, and security across global enterprise infrastructure.</li>
        <li>Orchestrate AWS cloud environments, focusing on cost optimization, IAM governance, and hardening security configurations.</li>
        <li>Architect proactive monitoring and incident response workflows to detect and remediate security threats in real-time.</li>
        <li>Manage vulnerability lifecycles and patch management cycles in alignment with NIST and HIPAA regulatory guidelines.</li>
        <li>Collaborate with cross-functional teams to deploy secure system integrations and high-performance APIs.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="System Integration Analyst"
      subtitle="Jan 2023 - August 2024 at HealtHIE Nevada | Nevada (Remote)"
    >
      <ul class="list-disc ml-5 space-y-2">
        <li>Engineered reporting for daily traffic monitoring to ensure data integrity across healthcare interfaces.</li>
        <li>Resolved complex application and interface discrepancies by managing critical support ticketing escalations.</li>
        <li>Validated CCDs to verify adherence to healthcare specifications and ensure successful data ingestion.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Production Support Engineer"
      subtitle="October 2021 - January 2023 at Sema4 OpCo Inc. | Connecticut"
    >
      <ul class="list-disc ml-5 space-y-2">
        <li>Partnered with Product Managers to identify infrastructure bottlenecks and implement efficiency-driven enhancements.</li>
        <li>Utilized SQL and Postman to debug and remediate interface and system-level issues for seamless operation.</li>
        <li>Monitored multi-stack dashboards to maintain high-availability systems and preemptive failure detection.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Support Lead"
      subtitle="January 2021 – October 2021 at ELLKAY, LLC. | New Jersey"
    >
      <ul class="list-disc ml-5 space-y-2">
        <li>Managed a team of 4 support analysts, delivering technical mentorship and ensuring project deadlines were met.</li>
        <li>Conducted performance reviews and professional development roadmaps for direct reports.</li>
        <li>Collaborated with Network/IT teams to facilitate VPN setups, migrations, and infrastructure changes.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Sr. Support Analyst"
      subtitle="January 2016 – December 2020 at ELLKAY, LLC. | New Jersey"
    >
      <ul class="list-disc ml-5 space-y-2">
        <li>Provided 24/7 specialized infrastructure monitoring and support for high-priority VIP healthcare clients.</li>
        <li>Analyzed and remediated network latency and connectivity issues across 80+ client sites.</li>
        <li>Mentored 8-10 junior staff members and collaborated across teams to deliver new infrastructure projects.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Connectivity Specialist"
      subtitle="November 2012 – December 2015 at ELLKAY, LLC. | New Jersey"
    >
      <ul class="list-disc ml-5 space-y-2">
        <li>Oversaw multiple concurrent technical projects, ensuring on-time delivery and alignment with laboratory requirements.</li>
        <li>Deployed and validated HL7 ADT/DFT/SIU interfaces to ensure compliant data exchange between vendors and labs.</li>
        <li>Collaborated with diverse patient management systems and databases to facilitate seamless system implementations.</li>
      </ul>
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold text-primary">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>AWS Certified Solutions Architect – Associate (SAA-C03)</li>
    <li>AWS Certified Security – Specialty (SCS-C03)</li>
    <li>CompTIA Security+ (SY0-701)</li>
    <li>ISC2 Certified in Cybersecurity</li>
    <li>Google Cybersecurity Professional Certificate</li>
    <li>API Security Fundamentals</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold text-primary">Skills</div>
  </div>

  <ul class="list-disc md:columns-3 columns-2 mx-6">
    <li>AWS (IAM, S3, VPC)</li>
    <li>NIST Cybersecurity Framework</li>
    <li>HIPAA Compliance</li>
    <li>HL7 & FHIR Interoperability</li>
    <li>SIEM (Microsoft Sentinel)</li>
    <li>Linux CLI & Python</li>
    <li>Wireshark & IDS Tools</li>
    <li>Azure AD & KQL</li>
    <li>Incident Response</li>
    <li>SQL & API Testing (Postman)</li>
    <li>Zendesk & Salesforce</li>
    <li>Technical Leadership</li>
  </ul>
</BaseLayout>