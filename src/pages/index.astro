---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";
import ProjectCard from '../components/ProjectCard.astro';

// 1. Fetch and Sort Projects
const allProjects = await getCollection("projects");
const securityProjects = allProjects.sort(
  (a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0)
);

// 2. Fetch and Sort Blog Posts (Fixed the duplicates here)
const allPosts = await getCollection("blog");
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const last_posts = posts.slice(0, 3);

// 3. Skills List
const skills = ["AWS Security", "IAM", "WAF", "Incident Response", "Linux", "CLI"];
---



<BaseLayout sideBarActiveItemID="home">
  
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
     <h1 class="text-5xl font-bold">
  I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">
    Sahil
  </span>
  
</h1>
    <div class="text-3xl py-3 font-bold">Technical Services Manager</div>


    <div class="flex flex-wrap gap-2 py-4">
      {skills.map((skill) => (
    <div class="badge badge-outline border-blue-500/30 text-blue-400 font-mono text-[10px] py-3 px-3 lowercase bg-blue-500/5">
      <span class="text-blue-700 mr-1 opacity-60 font-bold">skill:</span>{skill}
    </div>
  ))}
</div>

    <div class="py-2">
      <text class="text-lg">
        I am an IT Professional with 12 years of experience managing mission-critical infrastructure in Healthcare. I am currently bridging that expertise into Cloud Architecture and CyberSecurity, backed by AWS Solutions Architect and Security+ certifications. I specialize in building secure, resilient, and compliant cloud environments.  
      </text>
    </div>
<div class="mt-9">
<div class="mt-9">
    <div class="text-sm opacity-50 mb-4 uppercase tracking-widest font-bold text-primary">Verified Credentials</div>
    <div class="flex flex-wrap gap-8 items-center">
    <img src="/aws-saa.png" alt="AWS SAA" class="h-20 w-auto grayscale hover:grayscale-0 transition-all duration-300" alt="AWS Solutions Architect Associate" 
    title = "AWS Solutions Archtect Associate"/>

    <img src="/aws-scs.png" alt="AWS SCS" class="h-20 w-auto grayscale hover:grayscale-0 transition-all duration-300" alt="AWS Solutions Architect Associate" 
    title = "AWS Solutions Security Specialty"/>

    <img src="/security-plus.png" alt="Security+" class="h-20 w-auto grayscale hover:grayscale-0 transition-all duration-300" alt="CompTIA Security+" 
    title = "CompTIA Security+"/>
    
    <img src="/isc2-cc.png" alt="ISC2 CC" class="h-20 w-auto grayscale hover:grayscale-0 transition-all duration-300" alt="ISC2 Certified in Cybersecurity" 
    title = "ISC2 Certified in Cybersecurity"/>
   </div>
</div>
</div>
    <div class="mt-8 flex gap-4">
      <a class="btn btn-primary" href="/projects"> View Portfolio </a>
      <a href="https://github.com/farmprotector" target="_blank" class="btn btn-outline">
        Github
      </a>
      
    </div>
  </div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
  <div class="p-4 bg-slate-900/40 border border-slate-800 rounded-2xl">
    <div class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-1">Infrastructure</div>
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_#10b981]"></div>
      <span class="text-sm font-bold text-slate-200">SOC_OPERATIONAL</span>
    </div>
  </div>

  <div class="p-4 bg-slate-900/40 border border-slate-800 rounded-2xl">
    <div class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-1">Primary Region</div>
    <div class="text-sm font-bold text-slate-200 font-mono">us-east-1 (N. Virginia)</div>
  </div>

  <div class="p-4 bg-slate-900/40 border border-slate-800 rounded-2xl">
    <div class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-1">Security Score</div>
    <div class="text-sm font-bold text-blue-400 font-mono">98.4% Compliance</div>
  </div>
</div>



    <div>
    <div class="text-3xl w-full font-bold mb-2">Newest Projects {"</>"}</div>
  </div>



<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
  {securityProjects.slice(0, 4).map((project) => (
    <ProjectCard 
      title={project.data.title}
      description={project.data.description}
      tags={project.data.tags}
      url={`/projects/${project.slug}`}
      status={project.data.status}
      category={project.data.category} 
    />
  ))}
</div>

<div>
  <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
</div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
